# Canonical site URL for Open Graph and metadataBase (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Home hero background videos — full https:// URLs from Blob Browser (public store). Required on Vercel
# (there are no .mov files in git). After saving in the Vercel project, trigger a new deployment so the build picks them up.
NEXT_PUBLIC_HOME_HERO_VIDEO_DESKTOP=
NEXT_PUBLIC_HOME_HERO_VIDEO_MOBILE=
# Optional non-prefixed duplicates (same values); read on the server in HomeHeader.
HOME_HERO_VIDEO_DESKTOP=
HOME_HERO_VIDEO_MOBILE=

# Vercel Blob (after linking store: vercel env pull)
BLOB_READ_WRITE_TOKEN=

# Secret for /admin/hero-blob-upload — required to mint client upload tokens (pick a long random string)
HERO_BLOB_UPLOAD_SECRET=
