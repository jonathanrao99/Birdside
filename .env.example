# Canonical site URL for Open Graph and metadataBase (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Home hero background videos: paste each file's full URL from Vercel → Storage → your Blob → Browser (public blobs use *.public.blob.vercel-storage.com).
# Optional locally: leave empty to use /BirdsideDesktop.mov and /BirdsideHeroMobile.mov from public/ (gitignored) instead.
NEXT_PUBLIC_HOME_HERO_VIDEO_DESKTOP=
NEXT_PUBLIC_HOME_HERO_VIDEO_MOBILE=

# Vercel Blob (after linking store: vercel env pull)
BLOB_READ_WRITE_TOKEN=

# Secret for /admin/hero-blob-upload — required to mint client upload tokens (pick a long random string)
HERO_BLOB_UPLOAD_SECRET=
