# Canonical site URL for Open Graph and metadataBase (no trailing slash)
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Home hero background videos (full HTTPS URLs). Required for production if videos are not in /public.
# Optional locally: omit to use /BirdsideDesktop.mov and /BirdsideHeroMobile.mov from public/ (gitignored).
NEXT_PUBLIC_HOME_HERO_VIDEO_DESKTOP=
NEXT_PUBLIC_HOME_HERO_VIDEO_MOBILE=
